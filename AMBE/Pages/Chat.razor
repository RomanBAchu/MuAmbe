@page "/"
@using Microsoft.AspNetCore.Components.Web
@using AMBE.Pages

@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop

@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-container">
    <div class="messages-list" style="height: 200px; overflow-y: auto; background: #f0f0f0;">
        @foreach (var msg in messages) { <div><b>@msg.User:</b> @msg.Text</div> }
    </div>

    @* Сетка на 4 видео *@
    <div class="video-grid d-flex flex-wrap justify-content-center gap-2 p-2">
        <video id="localVideo" autoplay muted playsinline style="width:140px; background:black; border-radius:8px;"></video>
        <video id="remoteVideo1" autoplay playsinline style="width:140px; background:black; border-radius:8px;"></video>
        <video id="remoteVideo2" autoplay playsinline style="width:140px; background:black; border-radius:8px;"></video>
        <video id="remoteVideo3" autoplay playsinline style="width:140px; background:black; border-radius:8px;"></video>
    </div>

    <div class="text-center p-2">
        <button class="btn btn-success rounded-pill" @onclick="StartCall">📞 Позвонить</button>
    </div>

    <div class="input-group p-2">
        <input @bind="userName" class="form-control" placeholder="Имя" style="width:20%" />
        <input @bind="newMessage" @onkeyup="HandleKeyPress" class="form-control" placeholder="Сообщение..." style="width:60%" />
        <button class="btn btn-primary" @onclick="Send">OK</button>
    </div>
</div>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Чудило", newMessage = "";

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/chathub")).Build();

        hub.On<string, string>("ReceiveMessage", (u, t) => {
            messages.Add(new Message { User = u, Text = t });
            InvokeAsync(StateHasChanged);
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            if (signal.Contains("candidate")) {
                await JS.InvokeVoidAsync("addIceCandidate", signal, senderId);
            }
            else if (signal.Contains("offer")) {
                var answer = await JS.InvokeAsync<string>("processOffer", signal, senderId);
                await hub.SendAsync("SendSignal", answer, senderId);
            }
            else if (signal.Contains("answer")) {
                await JS.InvokeVoidAsync("processAnswer", signal, senderId);
            }
        });

        await hub.StartAsync();
        await JS.InvokeVoidAsync("prepareWebRTC", DotNetObjectReference.Create(this));
    }

    private async Task StartCall() {
        // "all" говорит JS создать оферы для каждого в комнате
        var offer = await JS.InvokeAsync<string>("createOffer", "all"); 
        if (hub != null) await hub.SendAsync("SendSignal", offer, "all");
    }

    [JSInvokable]
    public async Task SendIceCandidate(string candidate, string targetId) {
        if (hub != null) await hub.SendAsync("SendSignal", candidate, targetId);
    }

    private async Task Send() {
        if (hub != null && !string.IsNullOrWhiteSpace(newMessage)) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    public async ValueTask DisposeAsync() { if (hub != null) await hub.DisposeAsync(); }
    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
